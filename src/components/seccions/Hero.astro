---
import TranslatedText from "../TranslatedText.svelte";
---

<section id="hero" class="hero">
  <div class="background-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>

  <div class="container">
    <div class="hero-content">
      <div class="hero-left">
        <div class="text-wrapper">
          <h2 class="greeting">
            <TranslatedText
              key="heroGreeting"
              fallback="Hello, I'm"
              client:load
            />
          </h2>
          <h1 class="name">Yeifran Hernandez</h1>
          <div class="role-container">
            <span class="role-prefix">&gt; </span>
            <span class="role">
              <TranslatedText
                key="heroTitle"
                fallback="Full Stack Developer"
                client:load
              />
            </span>
            <span class="cursor">_</span>
          </div>
        </div>

        <div class="cta-group">
          <a href="#projects" class="btn-primary">
            <TranslatedText key="viewProjects" fallback="View Work" client:load />
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon"
              ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                points="12 5 19 12 12 19"></polyline></svg
            >
          </a>
          <a href="#contact" class="btn-secondary">
            <TranslatedText key="contactMe" fallback="Contact Me" client:load />
          </a>
        </div>
      </div>

      <div class="hero-right">
        <div class="profile-image-wrapper">
          <img
            src="/perfil.png"
            alt="Yeifran Hernandez - Full Stack Developer"
            class="profile-image"
            width="320"
            height="320"
            loading="eager"
          />
          <div class="status-badge">
            <span class="status-dot"></span>
            <TranslatedText key="availableForWork" fallback="Available for work" client:load />
          </div>
        </div>
      </div>
    </div>
  </div>

  <a href="#about" class="scroll-indicator" aria-label="Scroll down">
    <span class="mouse">
      <span class="wheel"></span>
    </span>
    <span class="arrow"></span>
    <span class="text">
      <TranslatedText key="scrollDown" fallback="Scroll down" client:load />
    </span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
    background: var(--bg);
    color: var(--text);
  }

  /* Animated Background */
  .background-blobs {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: float 20s infinite alternate;
  }

  .blob-1 {
    top: -10%;
    left: -10%;
    width: 50vw;
    height: 50vw;
    background: var(--primary);
    animation-delay: 0s;
  }

  .blob-2 {
    bottom: -10%;
    right: -10%;
    width: 60vw;
    height: 60vw;
    background: var(--secondary, #64ffda);
    animation-delay: -10s;
  }

  @keyframes float {
    0% {
      transform: translate(0, 0) scale(1);
    }
    100% {
      transform: translate(20px, 40px) scale(1.1);
    }
  }

  .container {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    z-index: 1;
    position: relative;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 4rem;
    width: 100%;
  }

  .hero-left {
    flex: 1;
  }

  .hero-right {
    flex-shrink: 0;
  }

  /* Profile Image */
  .profile-image-wrapper {
    position: relative;
    display: inline-block;
  }

  .profile-image {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 4px solid var(--accent);
    box-shadow:
      0 0 0 4px rgba(var(--accent-rgb), 0.15),
      0 0 30px rgba(var(--accent-rgb), 0.25),
      0 20px 40px rgba(0, 0, 0, 0.3);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    opacity: 0;
    animation: imageReveal 0.8s ease forwards 0.3s;
  }

  @keyframes imageReveal {
    from {
      opacity: 0;
      transform: scale(0.8) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .profile-image:hover {
    transform: scale(1.05) rotate(3deg);
    box-shadow:
      0 0 0 4px rgba(var(--accent-rgb), 0.25),
      0 0 50px rgba(var(--accent-rgb), 0.4),
      0 20px 50px rgba(0, 0, 0, 0.4);
  }

  .status-badge {
    position: absolute;
    bottom: 15px;
    right: 15px;
    background: rgba(var(--ink-rgb), 0.95);
    backdrop-filter: blur(10px);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    border: 1px solid rgba(var(--green-rgb), 0.3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--green);
    white-space: nowrap;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    opacity: 0;
    animation: badgeSlideIn 0.5s ease forwards 1s;
  }

  @keyframes badgeSlideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
  }

  /* Typography */
  .greeting {
    font-size: 1.25rem;
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards 0.2s;
  }

  .name {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--white);
    letter-spacing: -0.03em;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards 0.3s;
    background: linear-gradient(135deg, var(--white) 30%, var(--muted));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .role-container {
    display: flex;
    align-items: center;
    font-size: clamp(1.5rem, 5vw, 3rem);
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards 0.4s;
  }

  .role-prefix {
    margin-right: 0.5rem;
    color: var(--accent);
  }

  .cursor {
    display: inline-block;
    margin-left: 0.2rem;
    animation: blink 1s step-end infinite;
    color: var(--accent);
  }

  /* Buttons */
  .cta-group {
    display: flex;
    gap: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards 0.6s;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: .85rem 2rem;
    background: var(--accent);
    border: none;
    color: var(--ink);
    border-radius: 4px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: background .2s, transform .15s;
  }
  .btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }
  .btn-primary .icon { transition: transform 0.25s ease; }
  .btn-primary:hover .icon { transform: translateX(4px); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: .85rem 2rem;
    background: transparent;
    color: var(--light);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: var(--font-display);
    font-size: 0.9rem;
    text-decoration: none;
    transition: border-color .2s, color .2s;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeIn 1s ease forwards 1.5s;
    text-decoration: none;
    cursor: pointer;
  }

  .scroll-indicator .text {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-top: 0.5rem;
    font-weight: 500;
    opacity: 0.6;
    color: var(--muted);
  }

  .mouse {
    width: 26px; height: 40px;
    border: 2px solid var(--muted);
    border-radius: 20px;
    position: relative;
  }

  .wheel {
    position: absolute; top: 6px; left: 50%;
    transform: translateX(-50%);
    width: 4px; height: 4px;
    background: var(--accent); border-radius: 50%;
    animation: scroll 2s infinite;
  }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  @keyframes scroll {
    0%   { transform: translate(-50%, 0); opacity: 1; }
    100% { transform: translate(-50%, 15px); opacity: 0; }
  }

  /* Responsive */
  @media (max-width: 968px) {
    .hero-content {
      flex-direction: column-reverse;
      text-align: center;
      gap: 2rem;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .role-container {
      justify-content: center;
    }

    .cta-group {
      justify-content: center;
    }

    .profile-image {
      width: 220px;
      height: 220px;
    }
  }

  @media (max-width: 768px) {
    .hero { padding: 1.5rem; align-items: center; }
    .name { font-size: 3rem; }
    .role-container { font-size: 1.5rem; }
    .cta-group { flex-direction: column; width: 100%; gap: 1rem; }
    .btn-primary  { width: 100%; justify-content: center; }
    .btn-secondary { justify-content: center; }
    .profile-image { width: 180px; height: 180px; }
    .status-badge { font-size: 0.65rem; padding: 0.4rem 0.75rem; bottom: 10px; right: 10px; }
  }

  @media (max-width: 480px) {
    .profile-image { width: 150px; height: 150px; }
    .name { font-size: 2.5rem; }
  }
</style>
