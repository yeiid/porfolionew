---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Yeifran Hernandez — Full Stack Developer autodidacta de La Guajira, Colombia. React, Python, Node.js, IA. Fundador de NeuralJIRA. Bogotá, 2026."
    />
    <meta property="og:title" content="Yeifran Hernandez — Full Stack Developer" />
    <meta property="og:description" content="Developer autodidacta desde 2015. Proyectos reales en producción. Buscando primer empleo formal." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/perfil.png" />
    <meta
      name="keywords"
      content="desarrollador web, frontend, React, Node.js, JavaScript, Python, portafolio, Yeifran Hernandez, NeuralJIRA, full stack developer, Bogotá, Colombia"
    />
    <meta name="author" content="Yeifran Hernandez" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#F97316" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body id="top">
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <Header />

    <main class="main-content" id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<script is:inline>
  (function() {
    var saved = localStorage.getItem('language');
    if (saved) {
      document.documentElement.setAttribute('lang', saved === 'es' ? 'es' : 'en');
    }
  })();
</script>

<style>
  .main-content {
    padding-top: var(--header-height);
    min-height: calc(100vh - var(--header-height));
  }
</style>
