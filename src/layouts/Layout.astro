---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Portafolio de Yeifran Hernandez - Desarrollador Frontend especializado en React, Node.js y tecnologías web modernas. Proyectos innovadores y soluciones digitales."
    />
    <meta
      name="keywords"
      content="desarrollador web, frontend, React, Node.js, JavaScript, Python, portafolio, Yeifran Hernandez"
    />
    <meta name="author" content="Yeifran Hernandez" />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body id="top">
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <Header />

    <main class="main-content" id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  .main-content {
    padding-top: var(--header-height);
    min-height: calc(100vh - var(--header-height));
  }
</style>
